{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app/layout,_N_T_/app/rewards/layout,_N_T_/app/rewards/page,_N_T_/app/rewards"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/app/rewards/__PAGE__",
    "/app/rewards",
    "/app",
    "/_index",
    "/_head"
  ]
}