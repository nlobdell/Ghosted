{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app/layout,_N_T_/app/clan/layout,_N_T_/app/clan/page,_N_T_/app/clan"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/app/clan/__PAGE__",
    "/app/clan",
    "/app",
    "/_index",
    "/_head"
  ]
}