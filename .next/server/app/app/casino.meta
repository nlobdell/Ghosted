{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app/layout,_N_T_/app/casino/layout,_N_T_/app/casino/page,_N_T_/app/casino"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/app/casino/__PAGE__",
    "/app/casino",
    "/app",
    "/_index",
    "/_head"
  ]
}