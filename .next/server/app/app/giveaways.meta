{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app/layout,_N_T_/app/giveaways/layout,_N_T_/app/giveaways/page,_N_T_/app/giveaways"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/app/giveaways/__PAGE__",
    "/app/giveaways",
    "/app",
    "/_index",
    "/_head"
  ]
}