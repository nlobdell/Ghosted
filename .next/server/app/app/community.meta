{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app/layout,_N_T_/app/community/layout,_N_T_/app/community/page,_N_T_/app/community"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/app/community/__PAGE__",
    "/app/community",
    "/app",
    "/_index",
    "/_head"
  ]
}